# Glitch Grow AI Sales Agent — environment template
# Copy to .env and fill in. Every key is required unless marked optional.

# ─── Postgres ─────────────────────────────────────────────────────────────────
# Writable role on the sales_agent.* schema. Owns leads, drafts, sends, agent_memory.
POSTGRES_RW_URL=postgresql://sales_agent_rw:CHANGE_ME@localhost:5432/glitch_grow

# ─── Discovery (Google Places API New, SA-impersonation auth) ────────────────
# Auth is via Application Default Credentials → impersonate the configured SA.
# No API key required. The metadata server provides the source identity; the
# wrapper mints short-lived tokens for the target SA.
GCP_PROJECT_ID=capable-boulder-487806-j0
GCP_PLACES_TARGET_SA=glitch-vertex-ai@capable-boulder-487806-j0.iam.gserviceaccount.com
# Default search center + radius for v1 discovery (North York, ON).
DISCOVERY_CENTER_LAT=43.7615
DISCOVERY_CENTER_LNG=-79.4111
DISCOVERY_RADIUS_M=8000

# ─── Email (Resend transactional API — outbound only) ────────────────────────
# Domain (e.g. glitchexecutor.com) must be verified in Resend dashboard first.
# After verification, any address on that domain can be used as the From.
# Reply tracking uses the actual mailbox's IMAP (separate config below).
RESEND_API_KEY=
RESEND_FROM_EMAIL=support@glitchexecutor.com
RESEND_FROM_NAME=Tejas — Glitch Executor Labs
RESEND_REPLY_TO=support@glitchexecutor.com

# ─── CASL footer (legally required on every cold email) ───────────────────────
CASL_SENDER_NAME=Glitch Executor Labs (Nuraveda)
CASL_SENDER_ADDRESS=77 Huntley St, Toronto, ON

# ─── Discord (HITL surface) ───────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_APPROVAL_CHANNEL_ID=
DISCORD_ADMIN_USER_IDS=

# ─── HubSpot CRM mirror (Option A: Postgres canonical, HubSpot downstream) ───
# Private App token. Rotate in HubSpot UI: Settings → Integrations → Private
# Apps → <your app> → Auth → Rotate. NEVER paste this anywhere except .env.
HUBSPOT_PAT=
# Custom deal pipeline label. Per-product: future Glitch products use their
# own pipeline name in the same portal, e.g. "Glitch [X]".
HUBSPOT_PIPELINE_NAME=Glitch Budz
# Master switch. Set false in dev / CI to skip HubSpot calls entirely.
HUBSPOT_SYNC_ENABLED=false
# Optional, informational only.
HUBSPOT_PORTAL_ID=

# ─── LLM providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
# Bearer token required to call POST /agent/run. Required.
AGENT_RUN_TOKEN=
# Hard ceiling on outbound email per day. Warm-up: start at 5, ramp to 30 over 3 weeks.
OUTREACH_DAILY_CAP=5

# ─── Optional ─────────────────────────────────────────────────────────────────
# When set, the agent boots in dry-run mode — drafts are produced but never sent.
SALES_AGENT_DRY_RUN=false
LOG_LEVEL=INFO
